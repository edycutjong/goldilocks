# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to `.env` or `.env.local` and fill in the values.
# Example:
#   cp .env.example .env.local

# ── CROO SDK KEY ────────────────────────────────────────────────────
# Your CROO Agent SDK key (croo_sk_...) from the CROO Dashboard.
# Required in LIVE mode. Omit only when running with CROO_MOCK=true.
CROO_SDK_KEY=

# ── GOLDILOCKS SERVICE ID ───────────────────────────────────────────
# The registered service ID for this pricing-oracle agent. Register the
# service in the CROO Dashboard, then paste its ID here.
GOLDILOCKS_SERVICE_ID=

# ── ANTHROPIC API KEY ───────────────────────────────────────────────
# Used to generate the natural-language pricing rationale. If unset,
# Goldilocks falls back to a deterministic template rationale.
ANTHROPIC_API_KEY=

# ── HEALTH SERVER PORT (optional) ───────────────────────────────────
# Port for the PaaS health-check server. Defaults to 8080.
# PORT=8080

# ── MOCK MODE (optional) ────────────────────────────────────────────
# Set to true for offline development — no USDC spent, no WebSocket opened.
# CROO_MOCK=true
